# .env.example — copie para .env e preencha com valores reais
# NUNCA commitar o .env real

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBED_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Computer Vision (OCR)
AZURE_VISION_ENDPOINT=
VISION_KEY=

# Azure Blob Storage
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=
AZURE_CONTAINER_RAW=
AZURE_CONTAINER_DM=

# MongoDB Atlas
MONGO_URI=
MONGO_DB=

# Relluna — configuração da aplicação
RELLUNA_ENV=development
RELLUNA_VERSION=0.2.0
RELLUNA_MODE=test
RELLUNA_WORKER_ONCE=0
RELLUNA_WORKER_POLL_INTERVAL_S=5
RELLUNA_OCR_MIN_TEXT_LEN=20
RELLUNA_OCR_MAX_PAGES=3
RELLUNA_OCR_DPI=200
RELLUNA_TRANSCRIPTION_LANGUAGE=
RELLUNA_TRANSCRIPTION_MODEL=base

# Azure Key Vault (apenas em produção; APP_ENV=production)
APP_ENV=development
AZURE_KEYVAULT_URL=
